<?xml version="1.0" encoding="UTF-8"?>
<templates id="pos_cheque_information_template_receipt_screen" inherit_id="point_of_sale.template" xml:space="preserve">
	<t t-name="OrderReceiptInherit" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
		<xpath expr="//div[hasclass('receipt-change')]" position="before">
			<br/>
			<div>
				Cheque No.(s)
				<span t-esc="this.env.services.pos.getOrder().get_total_qty()" class="pos-receipt-right-align"/>
			</div>
		</xpath>
	</t>
</templates>