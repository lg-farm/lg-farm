<?xml version="1.0"?>
<odoo>
    <data>

        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@id='pos_interface_section']" position='before'>
                    <block title="Allow Cheque Information" id="cheque_information_info">
						<setting id="sett_cheque_information_info"
                                 string="Add Cheque Information."
                                 help="Display Cheque Information."
							    title="Don't turn this option on if you take orders on smartphones or tablets. Such devices already benefit from a native keyboard.">
							<field name="cheque_information"/>
						</setting>
					</block>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
